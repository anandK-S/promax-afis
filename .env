# ========================================
# Pro-Max AFIS - Environment Configuration
# ========================================

# Application Configuration
APP_NAME=Pro-Max AFIS
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production-use-openssl-rand-hex-32

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/promax_db
TIMESCALEDB_ENABLED=True

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1

# Security & Authentication
JWT_SECRET_KEY=your-jwt-secret-key-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Hashing (Argon2)
PASSWORD_HASH_MEMORY=65536
PASSWORD_HASH_TIME=3
PASSWORD_HASH_PARALLELISM=4
PASSWORD_HASH_LENGTH=32

# OAuth2 Configuration
OAUTH2_CLIENT_ID=your-oauth2-client-id
OAUTH2_CLIENT_SECRET=your-oauth2-client-secret
OAUTH2_REDIRECT_URI=http://localhost:3000/auth/callback
OAUTH2_SCOPES=openid profile email

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=True
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-app-password
EMAIL_FROM=noreply@promax-afis.com
EMAIL_FROM_NAME=Pro-Max AFIS

# UPI Integration
UPI_API_KEY=your-upi-api-key
UPI_MERCHANT_ID=your-merchant-id
UPI_WEBHOOK_SECRET=your-webhook-secret

# GST Integration
GST_API_KEY=your-gst-api-key
GST_USERNAME=your-gst-username
GST_PASSWORD=your-gst-password
GST_SANDBOX=True

# ML Models Configuration
ML_MODEL_PATH=./ml-models/trained_models
ML_RETRAINING_ENABLED=True
ML_RETRAINING_SCHEDULE=0 2 * * *
ML_MODEL_VERSION=v1.0.0

# Voice Processing (Whisper)
WHISPER_MODEL_SIZE=base
WHISPER_LANGUAGE=en
WHISPER_DEVICE=cpu

# WhatsApp Integration
WHATSAPP_API_KEY=your-whatsapp-api-key
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_TEMPLATE_APPROVED=True

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/app.log
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# API Configuration
API_PREFIX=/api/v1
API_DOCS_ENABLED=True
API_REDOC_ENABLED=True

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=1000

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_EXTENSIONS=.csv,.xlsx,.xls,.pdf,.png,.jpg,.jpeg

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=280

# Monitoring & Analytics
GOOGLE_ANALYTICS_ID=your-ga-tracking-id
SENTRY_DSN=your-sentry-dsn
PROMETHEUS_ENABLED=True

# Frontend Configuration (for reference)
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws
VITE_ENABLE_VOICE=True
VITE_ENABLE_DARK_MODE=True
VITE_ENABLE_MULTI_LANGUAGE=True

# Feature Flags
ENABLE_VOICE_FEATURES=True
ENABLE_ML_PREDICTIONS=True
ENABLE_AUTO_CATEGORIZATION=True
ENABLE_ANOMALY_DETECTION=True
ENABLE_SCENARIO_SIMULATOR=True
ENABLE_REAL_TIME_ALERTS=True

# Timezone & Locale
TIMEZONE=Asia/Kolkata
LOCALE=en_IN
CURRENCY=INR